# Viper portal
AUTH_SERVICE_URL=http://localhost:4000
VIPER_URL=http://localhost:3400
VIPER_TEMPLATE_DIR=../../template
VIPER_BASE_DOMAIN=127.0.0.1.sslip.io
# http in local dev; flip to https once Traefik+Let's Encrypt are live (SPEC §4.2) — also
# controls the portal's own session cookie's Secure flag.
VIPER_DOMAIN_SCHEME=http

# Operator key the portal uses to call the auth service as itself (x-viper-admin header) —
# /session/check for the portal's own login, and member invites. Must match the auth service's
# AUTH_ADMIN_KEY. Generate via: openssl rand -hex 24
AUTH_ADMIN_KEY=

# Escape hatch ONLY — skips the portal's own login wall entirely (lib/session.ts). Do not set
# this on a portal instance meant to be gated for real; it exists for local scripting/testing.
PORTAL_DEV_BYPASS=

# Coolify — leave blank until Coolify is set up; the portal degrades gracefully (zip still ships).
COOLIFY_URL=
COOLIFY_TOKEN=
COOLIFY_SERVER_UUID=
COOLIFY_PROJECT_UUID=

# Insforge (SPEC §0.3) — per-project database provisioning (management API). Leave blank until
# an insforge.dev org + uak_ user API key exist; lib/dbprovider.ts degrades gracefully (Database
# tab shows "not configured yet", zip/deploy env omit DATABASE_URL).
INSFORGE_USER_API_KEY=
INSFORGE_ORG_ID=
