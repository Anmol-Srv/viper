# Viper auth service
PORT=4000
# Login is hard-locked to this email domain:
AUTH_EMAIL_DOMAIN=@airtribe.live
# Sign key for session JWTs. CHANGE in prod.
AUTH_JWT_SECRET=dev-insecure-secret-change-me
# NODE_ENV=production hides devOtp from responses (real email delivery would go here).
# Operator key for admin-only routes (rotate-secret, member management, DELETE /projects/:id,
# /session/check on any project). Generate via:
#   openssl rand -hex 24
AUTH_ADMIN_KEY=
# Owner of the seeded prj_viper (Viper Portal) project. Defaults to enggv2@airtribe.live.
AUTH_PLATFORM_ADMIN=
# Postmark server token — if set, OTP emails send via the Postmark HTTP API (checked first).
POSTMARK_TOKEN=
# SMTP connection URL (nodemailer) — used if POSTMARK_TOKEN is unset. e.g. smtp://user:pass@host:587
SMTP_URL=
# From address for OTP emails when a real transport (Postmark/SMTP) is configured.
MAIL_FROM=viper@airtribe.live
