# Viper auth service
PORT=4000
# Login is hard-locked to this email domain:
AUTH_EMAIL_DOMAIN=@airtribe.live
# Sign key for session JWTs. CHANGE in prod.
AUTH_JWT_SECRET=dev-insecure-secret-change-me
# NODE_ENV=production hides devOtp from responses (real email delivery would go here).
# Operator key for admin-only routes (rotate-secret, member management). Generate via:
#   openssl rand -hex 24
AUTH_ADMIN_KEY=
